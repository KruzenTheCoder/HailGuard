# HailGuard Driver Hub — copy to .env and fill in.
# Public Expo vars are inlined into the app at build time (EXPO_PUBLIC_*).

# --- Supabase (required) ---
# Project Settings → API
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# --- Payments (future / optional) ---
# The app currently uses a stub provider. When wiring a real gateway, expose
# only the PUBLIC/checkout key here; secrets must stay server-side.
# EXPO_PUBLIC_PAYFAST_MERCHANT_ID=
# EXPO_PUBLIC_PAYFAST_MERCHANT_KEY=
# EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=
